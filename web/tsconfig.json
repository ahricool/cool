{
  "compilerOptions": {
    "target": "ESNext",
    "useDefineForClassFields": true,
    "module": "ESNext",
    "lib": ["ESNext", "DOM", "DOM.Iterable"],
    "moduleResolution": "Bundler",
    "strict": true,
    "sourceMap": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "esModuleInterop": true,
    "noEmit": true,
    "noUnusedLocals": false,
    "noUnusedParameters": false,
    "noImplicitReturns": true,
    "skipLibCheck": true,
    "paths": {
      "@/*": ["./src/*"]
    }
  },
  "include": [
    "src/main.ts",
    "src/App.ts",
    "src/router.ts",
    "src/api/**/*.ts",
    "src/components/**/*.ts",
    "src/stores/**/*.ts",
    "src/views/**/*.ts",
    "src/**/*.d.ts",
    "vite-env.d.ts"
  ]
}
