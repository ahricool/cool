# API Base URL – calls are proxied to Strapi in development via vite.config.ts
VITE_API_BASE=/api

# For production, point directly to your Strapi server
# VITE_API_BASE=https://api.example.com/api

# Site Configuration (optional overrides; Strapi site-config takes precedence at runtime)
# VITE_SITE_TITLE=My Blog
# VITE_SITE_URL=https://example.com
